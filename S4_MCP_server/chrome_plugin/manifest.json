{
  "manifest_version": 3,
  "name": "EAG Stock Analyst",
  "version": "1.0",
  "description": "Agentic Stock Analysis Chatbot",
  "action": {
    "default_title": "Analyze Stocks"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "permissions": [
    "sidePanel"
  ],
  "host_permissions": [
    "http://127.0.0.1:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
